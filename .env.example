NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Protects /api/cron/ingest
CRON_SECRET=

# Endpoint returning JSON:
# { "posts": [{ "postUrl": "...", "caption": "...", "mediaUrl": "...", "postedAt": "ISO", "externalId": "...", "raw": {} }] }
INSTAGRAM_SOURCE_ENDPOINT=
INSTAGRAM_SOURCE_API_KEY=

# Python OCR worker
PY_WORKER_CHECK_INTERVAL_SECONDS=600
PY_WORKER_MAX_POSTS_PER_ACCOUNT=8
PY_WORKER_REQUEST_TIMEOUT_SECONDS=30
PY_WORKER_DELAY_BETWEEN_ACCOUNTS_SECONDS=3
PY_WORKER_DELAY_BETWEEN_POSTS_SECONDS=1
PY_WORKER_TMP_DIR=python-worker/tmp
PY_WORKER_LOG_LEVEL=INFO
PY_WORKER_DRY_RUN=false
PY_WORKER_RUN_ONCE=false

# Optional: if Tesseract is not in PATH
TESSERACT_CMD=

# Optional: authenticated Instaloader session/login
INSTALOADER_SESSION_FILE=python-worker/instaloader.session
INSTALOADER_LOGIN_USERNAME=
INSTALOADER_LOGIN_PASSWORD=
